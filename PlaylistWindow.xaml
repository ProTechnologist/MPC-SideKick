<Window x:Class="PanelApp.PlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PanelApp"
        mc:Ignorable="d"
        Title="Playlist" Height="600" Width="260"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        Topmost="True" ResizeMode="NoResize" ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Modern Ultra-Thin Floating ScrollBar (2px) -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="2"/>
            <Setter Property="MinWidth" Value="2"/>
            <Setter Property="MaxWidth" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent" Width="2">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#6644AAFF" Width="2" MinWidth="2" MaxWidth="2">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Rectangle Fill="{TemplateBinding Background}" Width="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                                      Value="{TemplateBinding VerticalOffset}"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      HorizontalAlignment="Right" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slide Animation (From Right) -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="SlideOut">
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="260" Duration="0:0:0.3" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border x:Name="MainContent" Background="#F20A0E1A" CornerRadius="12,0,0,12" Margin="0,5,0,5" BorderBrush="#2244AAFF" BorderThickness="1,1,0,1">
            <Border.RenderTransform>
                <TranslateTransform X="260"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="#44AAFF"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Toolbar -->
                <Grid Grid.Row="0" Margin="10,20,10,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Click="Shuffle_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="8,0" ToolTip="Shuffle Playlist">
                            <TextBlock Text="🔀" FontSize="18" Foreground="#CC44AAFF"/>
                        </Button>
                        
                        <ToggleButton x:Name="PinToggle" Click="PinToggle_Click" Background="Transparent" BorderThickness="0" Margin="8,0" ToolTip="Pin Playlist">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="6" Padding="4">
                                        <Image Source="/pin-icon.png" Width="24" Height="24" x:Name="PinImage" Opacity="0.4"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="PinImage" Property="Opacity" Value="1.0"/>
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#2244AAFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#1144AAFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Button Click="ClearAll_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="8,0" ToolTip="Clear All">
                            <TextBlock Text="🗑️" FontSize="18" Foreground="#CCFF4444"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Playlist View -->
                <ListView x:Name="PlaylistListView" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          MouseDoubleClick="PlaylistListView_MouseDoubleClick" Margin="0" Padding="0"
                          d:ItemsSource="{x:Static local:PlaylistManager.Instance.Items}"
                          PreviewMouseLeftButtonDown="PlaylistListView_PreviewMouseLeftButtonDown"
                          MouseMove="PlaylistListView_MouseMove"
                          DragEnter="PlaylistListView_DragOver"
                          DragOver="PlaylistListView_DragOver"
                          Drop="PlaylistListView_Drop"
                          AllowDrop="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2" Width="250" Height="140" x:Name="ItemGrid">
                                <Border CornerRadius="6" ClipToBounds="True" Background="#08FFFFFF">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <!-- Overlay -->
                                        <Border VerticalAlignment="Bottom" MinHeight="55">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#E6000000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="12" 
                                                       Margin="10,0,10,8" VerticalAlignment="Bottom"
                                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                       LineHeight="14" Height="28"/>
                                        </Border>

                                        <!-- Remove (X) Button -->
                                        <Button x:Name="RemoveBtn" Content="×" Click="RemoveFromPlaylist_Click" 
                                                HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                Margin="8" Width="26" Height="26" 
                                                Background="#99FF4444" Foreground="White" FontWeight="Bold" FontSize="18"
                                                Visibility="Collapsed">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="13">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True" SourceName="ItemGrid">
                                    <Setter TargetName="RemoveBtn" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="5,3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#1A44AAFF"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#3344AAFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#3344AAFF"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#AA44AAFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
