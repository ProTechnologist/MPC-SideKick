<Window x:Class="PanelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PanelApp"
        mc:Ignorable="d"
        Title="Companion Panel" Height="600" Width="200"
        WindowStyle="None" AllowsTransparency="True" Background="#CC1E1E1E" 
        Topmost="True" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="10">
            <Button Content="Select Video Folder" Click="SelectFolder_Click" Background="#444" Foreground="White" BorderBrush="Transparent" Padding="5"/>
            <TextBlock x:Name="FolderPathText" Text="No folder selected" Foreground="Gray" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>

        <ListView x:Name="VideoListView" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="VideoListView_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5" Width="170">
                        <Image Source="{Binding Thumbnail}" Width="160" Height="90" Stretch="UniformToFill">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,160,90" RadiusX="4" RadiusY="4"/>
                            </Image.Clip>
                        </Image>
                        <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="11" Margin="0,5,0,0" 
                                   TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="2" CornerRadius="4">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#66FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
        
        <!-- Handle for dragging if needed, but we usually stick to MPC-BE -->
        <Thumb DragDelta="Thumb_DragDelta" Opacity="0" VerticalAlignment="Top" Height="10" Grid.Row="0"/>
    </Grid>
</Window>
