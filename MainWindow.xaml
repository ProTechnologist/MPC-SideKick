<Window x:Class="PanelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PanelApp"
        mc:Ignorable="d"
        Title="Companion Panel" Height="600" Width="200"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        Topmost="True" ResizeMode="NoResize" ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Custom Slim ScrollBar -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#66FFFFFF" Opacity="0.5">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Rectangle Fill="{TemplateBinding Background}" RadiusX="3" RadiusY="3" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slide Animation -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="SlideOut">
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="-200" Duration="0:0:0.3" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border x:Name="MainContent" Background="#EE1E1E1E" CornerRadius="0,8,8,0" Margin="0,5,0,5" BorderBrush="#33FFFFFF" BorderThickness="0,1,1,1">
            <Border.RenderTransform>
                <TranslateTransform X="-200"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Icon Toolbar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15,15,15,5" HorizontalAlignment="Center">
                    <Button Click="SelectFolder_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,10,0" x:Name="FolderBtn">
                        <Button.ToolTip>
                            <ToolTip x:Name="FolderTooltip" Content="Select Video Folder"/>
                        </Button.ToolTip>
                        <Image Source="/folder-icon.png" Width="24" Height="24"/>
                    </Button>
                    
                    <ToggleButton x:Name="PinToggle" Click="PinToggle_Click" Margin="0,0,10,0" ToolTip="Pin/Unpin Panel" Background="Transparent" BorderThickness="0">
                        <Image Source="/pin-icon.png" Width="24" Height="24" x:Name="PinImage" Opacity="0.5"/>
                    </ToggleButton>

                    <Button Click="Settings_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" ToolTip="Settings">
                        <Image Source="/settings-icon.png" Width="24" Height="24"/>
                    </Button>
                </StackPanel>

                <!-- Search Box -->
                <Border Grid.Row="1" Margin="15,5,15,10" Background="#1AFFFFFF" CornerRadius="4" BorderBrush="#33FFFFFF" BorderThickness="1">
                    <Grid>
                        <TextBox x:Name="SearchBox" Background="Transparent" Foreground="White" BorderThickness="0" 
                                 Padding="5,3" TextChanged="SearchBox_TextChanged" VerticalContentAlignment="Center"/>
                        <TextBlock IsHitTestVisible="False" Text="Search videos..." VerticalAlignment="Center" 
                                   HorizontalAlignment="Left" Margin="8,0,0,0" Foreground="#44FFFFFF">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <ListView x:Name="VideoListView" Grid.Row="2" Background="Transparent" BorderThickness="0" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          MouseDoubleClick="VideoListView_MouseDoubleClick" Margin="5">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5" Width="160">
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="{Binding Thumbnail}" Width="150" Height="85" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding FileName}" Foreground="#CCFFFFFF" FontSize="11" Margin="0,6,0,0" 
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="4" CornerRadius="6">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
