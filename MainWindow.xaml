<Window x:Class="PanelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PanelApp"
        mc:Ignorable="d"
        Title="Companion Panel" Height="600" Width="260"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        Topmost="True" ResizeMode="NoResize" ShowInTaskbar="False">
    
    <Window.Resources>
        <local:NotEmptyConverter x:Key="NotEmptyConverter" />
        <!-- Modern Ultra-Thin Floating ScrollBar (2px) -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="2"/>
            <Setter Property="MinWidth" Value="2"/>
            <Setter Property="MaxWidth" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent" Width="2">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="#88FFFFFF" Width="2" MinWidth="2" MaxWidth="2">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Rectangle Fill="{TemplateBinding Background}" Width="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ScrollViewer to make ScrollBar float over content -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                                      Value="{TemplateBinding VerticalOffset}"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      HorizontalAlignment="Right" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slide Animation -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="SlideOut">
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="-260" Duration="0:0:0.3" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border x:Name="MainContent" Background="#F2121212" CornerRadius="0,12,12,0" Margin="0,5,0,5" BorderBrush="#22FFFFFF" BorderThickness="0,1,1,1">
            <Border.RenderTransform>
                <TranslateTransform X="-260"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.7"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Icon Toolbar -->
                <Grid Grid.Row="0" Margin="10,20,10,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Click="SelectFolder_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,8,0" x:Name="FolderBtn">
                            <Button.ToolTip><ToolTip x:Name="FolderTooltip" Content="Select Video Folder"/></Button.ToolTip>
                            <Image Source="/folder-icon.png" Width="24" Height="24" Opacity="0.9"/>
                        </Button>
                        <Button Click="Settings_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,8,0">
                            <Image Source="/settings-icon.png" Width="24" Height="24" Opacity="0.9"/>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ToggleButton x:Name="PinToggle" Click="PinToggle_Click" Background="Transparent" BorderThickness="0" Margin="8,0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="6" Padding="6">
                                        <Image Source="/pin-icon.png" Width="24" Height="24" x:Name="PinImage" Opacity="0.4"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="PinImage" Property="Opacity" Value="1.0"/>
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#1AFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </StackPanel>
                </Grid>

                <!-- Sharp Search Box (No Rounded Corners) -->
                <Border Grid.Row="1" Margin="15,0,15,20" Background="#1AFFFFFF" CornerRadius="0" BorderBrush="#1AFFFFFF" BorderThickness="1">
                    <Grid>
                        <TextBox x:Name="SearchBox" Background="Transparent" Foreground="White" BorderThickness="0" 
                                 Padding="10,6" TextChanged="SearchBox_TextChanged" VerticalContentAlignment="Center"
                                 CaretBrush="White" SelectionBrush="#44FFFFFF" FontSize="16"/>
                        <TextBlock IsHitTestVisible="False" Text="Search your library..." VerticalAlignment="Center" 
                                   HorizontalAlignment="Left" Margin="12,0,0,0" Foreground="#33FFFFFF" FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <!-- Clear Search Button -->
                        <Button x:Name="ClearSearchBtn" Content="×" Click="ClearSearch_Click" 
                                HorizontalAlignment="Right" VerticalAlignment="Center" 
                                Margin="0,0,8,0" Width="20" Height="20" 
                                Background="Transparent" Foreground="#66FFFFFF" FontWeight="Bold" FontSize="14"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox, Converter={StaticResource NotEmptyConverter}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Video List -->
                <ListView x:Name="VideoListView" Grid.Row="2" Background="Transparent" BorderThickness="0" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          MouseDoubleClick="VideoListView_MouseDoubleClick" Padding="0" Margin="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2" Width="250" Height="140" x:Name="ItemGrid">
                                <Border CornerRadius="6" ClipToBounds="True" Background="#11FFFFFF">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <!-- Bottom Gradient Overlay -->
                                        <Border VerticalAlignment="Bottom" MinHeight="55">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#E6000000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="13" 
                                                       Margin="10,0,10,8" VerticalAlignment="Bottom"
                                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                       LineHeight="16" LineStackingStrategy="BlockLineHeight"
                                                       Height="34"/>
                                        </Border>

                                        <!-- Quick Add (+) Button -->
                                        <Button x:Name="AddBtn" Content="+" Click="TogglePlaylist_Click" 
                                                HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                Margin="8" Width="30" Height="30" 
                                                Background="#99000000" Foreground="White" FontWeight="Bold" FontSize="18">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInPlaylist}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Content" Value="+"/>
                                                            <Setter Property="Background" Value="#99000000"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsInPlaylist}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Content" Value="✓"/>
                                                            <Setter Property="Background" Value="#9911CC11"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#CC000000"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="5,3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#22FFFFFF"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#44FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#AAFFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
